---
title: Main layout template
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    {# Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cutive+Mono&family=Reenie+Beanie&display=swap" rel="stylesheet">
    {# End Google Fonts #}

    <link href="/css/style.css" rel="stylesheet">
    <title>{{ title }}</title>
  </head>
  <body class="flex flex-col mx-4 xl:mx-auto max-w-screen-xl min-h-screen">
    <header class="flex justify-between items-end pt-6 pb-4 px-4 mb-4 border-solid border-b-4 border-zinc-600">
      <a href="/" class="font-handwriting text-5xl">Andy Carlberg</a>
      <nav>
        <ul class="flex font-mono text-2xl">
          <li class="mx-2 px-2 border-b-2 border-solid border-transparent hover:border-zinc-600 focus:border-zinc-600 active:border-zinc-600">
            <a href="/about-me">About me</a>
          </li>
        </ul>
      </nav>
    </header>
    <main class="grow px-4">
    {{ content | safe }}
    </main>
    <footer class="py-4 text-center text-xs">
      <section class="py-2">
        <p class="flex justify-center">
          <a href="https://github.com/andycarlberg/andycarlberg.com" target="_blank" class="flex justify-center items-center hover:underline">
            <svg viewBox="0 0 16 16" class="inline w-5 h-5 fill-current mr-1"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path></svg>
            <span class="ml-1">View on GitHub</span>
          </a>
      </section>
      <section class="py-2">
        <p>
          Copyright © {% year %} Andy Carlberg
        </p>
      </section>
    </footer>
  </body>
</html>
