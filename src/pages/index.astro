---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import homepageImage from "../assets/homepage.jpg";
import PostCard from "../components/PostCard.astro";
import Layout from "../layouts/Layout.astro";

export const prerender = true;

const allPosts = await getCollection("posts");
const latestPosts = allPosts
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3); // Top 3 posts

const title = "Andy Carlberg | Engineering Leadership & Product Stewardship";
const description =
  "Engineering leader bridging the gap between Engine and Economics. I build high-agency organizations that turn technical integrity into a durable business asset.";
---

<Layout title={title} description={description}>
  {/* Hero Section */}
  <section class="pt-32 pb-24 md:pt-48 md:pb-32 px-6">
    <div class="max-w-7xl mx-auto grid md:grid-cols-2 gap-16 items-center">
      <div>
        <span class="font-label-caps text-[12px] text-primary uppercase tracking-[0.2em] mb-4 block font-semibold">Strategic Leadership</span>
        <h1 class="font-headline-xl text-4xl md:text-5xl lg:text-[48px] leading-[1.1] tracking-[-0.02em] font-extrabold mb-6 text-slate-900 dark:text-white mt-0">
          Precision in execution.<br/>Strategy through transparency.
        </h1>
        <p class="font-body-lg text-[18px] leading-[1.7] text-on-surface-variant max-w-[600px] mb-8">
          Architecting scalable technology solutions for global enterprises. I help organizations navigate complex digital transformations with a focus on structural integrity and long-term value.
        </p>
        <div class="flex gap-4">
          <a href="/posts" class="bg-primary text-on-primary px-8 py-4 rounded font-body-md font-bold hover:brightness-110 transition-all active:scale-95 text-center inline-block">
            Read Insights
          </a>
          <a href="/topics" class="border border-slate-900 dark:border-white text-slate-900 dark:text-white px-8 py-4 rounded font-body-md font-bold hover:bg-slate-50 dark:hover:bg-slate-800 transition-all active:scale-95 text-center inline-block">
            View Projects
          </a>
        </div>
      </div>
      <div class="relative">
        <div class="aspect-square rounded-xl overflow-hidden grayscale contrast-125 border border-slate-200 dark:border-slate-800">
          <Image
            src={homepageImage}
            alt="Close-up professional portrait of Andy Carlberg"
            widths={[640, 768, 1280]}
            sizes="(max-width: 767px) 100vw, 50vw"
            loading="eager"
            class="w-full h-full object-cover m-0 block"
          />
        </div>
        <div class="absolute -bottom-6 -left-6 bg-white dark:bg-slate-900 p-6 rounded-lg shadow-xl border border-slate-100 dark:border-slate-800 hidden lg:block">
          <p class="font-headline-md text-[24px] leading-[1.3] font-semibold text-primary m-0">15+</p>
          <p class="font-label-caps text-[12px] text-slate-500 uppercase tracking-wider font-semibold m-0">Years of Impact</p>
        </div>
      </div>
    </div>
  </section>

  {/* Core Strategic Domains (Bento Grid) */}
  <section class="py-[6rem] px-6 bg-surface-container-low">
    <div class="max-w-7xl mx-auto">
      <div class="mb-16">
        <h2 class="font-headline-lg text-[32px] font-bold leading-[1.2] tracking-[-0.01em] text-slate-900 dark:text-white mb-2 mt-0">Core Strategic Domains</h2>
        <p class="font-body-md text-[16px] leading-[1.6] text-slate-500 max-w-xl m-0">A focused approach to engineering management and business growth.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {/* Enterprise Architecture */}
        <div class="md:col-span-2 bg-white dark:bg-slate-900 p-10 rounded-xl border border-slate-100 dark:border-slate-800 hover:shadow-lg transition-all group">
          <Icon name="lucide:blocks" class="text-primary w-10 h-10 mb-6" />
          <h3 class="font-headline-md text-[24px] font-semibold mb-4 mt-0 text-slate-900 dark:text-white">Enterprise Architecture</h3>
          <p class="font-body-md text-[16px] text-slate-600 dark:text-slate-400 mb-6">Designing resilient, distributed systems that sustain high-velocity growth while maintaining security and compliance standards.</p>
          <div class="flex gap-2">
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant font-label-caps text-[10px] font-semibold uppercase tracking-wider rounded">Scalability</span>
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant font-label-caps text-[10px] font-semibold uppercase tracking-wider rounded">Cloud-Native</span>
            <span class="px-3 py-1 bg-surface-container text-on-surface-variant font-label-caps text-[10px] font-semibold uppercase tracking-wider rounded">DevOps</span>
          </div>
        </div>

        {/* Strategic Planning */}
        <div class="bg-primary-container p-10 rounded-xl border border-primary text-white hover:shadow-lg transition-all flex flex-col justify-between">
          <div>
            <Icon name="lucide:chart-spline" class="w-10 h-10 mb-6" />
            <h3 class="font-headline-md text-[24px] font-semibold text-white mb-4 mt-0">Strategic Planning</h3>
            <p class="font-body-md text-[16px] opacity-90 m-0">Aligning technical roadmaps with long-term business objectives to drive sustainable ROI.</p>
          </div>
          <Icon name="lucide:trending-up" class="w-8 h-8 self-end mt-8" />
        </div>

        {/* Operational Excellence */}
        <div class="bg-white dark:bg-slate-900 p-10 rounded-xl border border-slate-100 dark:border-slate-800 hover:shadow-lg transition-all">
          <Icon name="lucide:users" class="text-primary w-10 h-10 mb-6" />
          <h3 class="font-headline-md text-[24px] font-semibold mb-4 mt-0 text-slate-900 dark:text-white">Operational Excellence</h3>
          <p class="font-body-md text-[16px] text-slate-600 dark:text-slate-400 m-0">Fostering cultures of accountability, mentorship, and high-performance engineering standards.</p>
        </div>

        {/* Product Lifecycle */}
        <div class="md:col-span-2 bg-white dark:bg-slate-900 p-10 rounded-xl border border-slate-100 dark:border-slate-800 hover:shadow-lg transition-all flex flex-col md:flex-row gap-10">
          <div class="flex-1">
            <Icon name="lucide:box" class="text-primary w-10 h-10 mb-6" />
            <h3 class="font-headline-md text-[24px] font-semibold mb-4 mt-0 text-slate-900 dark:text-white">Product Lifecycle</h3>
            <p class="font-body-md text-[16px] text-slate-600 dark:text-slate-400 m-0">From ideation to sunsetting, managing the full product lifecycle with data-driven precision.</p>
          </div>
          <div class="flex-1 bg-slate-50 dark:bg-slate-800 rounded-lg p-6 flex items-center justify-center">
            <div class="text-center">
              <p class="text-4xl font-extrabold text-slate-900 dark:text-white m-0">98%</p>
              <p class="font-label-caps text-[12px] text-slate-500 font-semibold uppercase tracking-wider m-0 mt-2">Efficiency Gain</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Latest Thinking Section */}
  <section class="py-[6rem] px-6">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-4">
        <div>
          <h2 class="font-headline-lg text-[32px] font-bold leading-[1.2] tracking-[-0.01em] text-slate-900 dark:text-white mb-2 mt-0">Latest Thinking</h2>
          <p class="font-body-md text-[16px] leading-[1.6] text-slate-500 max-w-xl m-0">Deep dives into the intersection of technology, leadership, and market strategy.</p>
        </div>
        <a class="text-primary font-bold hover:underline flex items-center gap-2" href="/posts">
          View Archive <Icon name="lucide:arrow-right" class="w-4 h-4" />
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {latestPosts.map((post) => (
          <PostCard
            title={post.data.title}
            slug={post.slug}
            description={post.data.description}
            publishDate={post.data.publishDate}
            tags={post.data.tags}
            image={post.data.image}
            body={post.body}
          />
        ))}
      </div>
    </div>
  </section>

  {/* Newsletter / Contact CTA */}
  <section class="py-[6rem] px-6 bg-slate-900 text-white overflow-hidden relative">
    <div class="absolute top-0 right-0 w-1/2 h-full opacity-10 pointer-events-none">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="currentColor" stroke-width="0.5"></path>
          </pattern>
        </defs>
        <rect width="100" height="100" fill="url(#grid)"></rect>
      </svg>
    </div>
    <div class="max-w-7xl mx-auto relative z-10 flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1">
        <h2 class="font-headline-lg text-[32px] font-bold leading-[1.2] tracking-[-0.01em] mb-4 mt-0 text-white">Building something significant?</h2>
        <p class="font-body-lg text-[18px] leading-[1.7] opacity-70 mb-0">I am currently available for strategic consulting and executive advisory roles for Series B+ startups and global enterprises.</p>
      </div>
      <div class="flex-1 w-full max-w-md">
        <form action="/api/contact" method="POST" class="space-y-4">
          <div class="flex flex-col gap-2">
            <input
              type="email"
              name="email"
              placeholder="Your executive email"
              class="bg-slate-800/50 border border-slate-700 rounded-lg px-6 py-4 text-white focus:outline-none focus:ring-2 focus:ring-primary placeholder:text-slate-500 font-body-md"
            />
            <button type="submit" class="bg-primary hover:bg-primary-container text-white px-8 py-4 rounded-lg font-bold transition-all active:scale-95 block text-center">
              Get in Touch
            </button>
          </div>
          <p class="text-[10px] font-label-caps text-slate-500 uppercase font-semibold tracking-wider text-center m-0">Inquiries typically answered within 48 business hours.</p>
        </form>
      </div>
    </div>
  </section>
</Layout>
