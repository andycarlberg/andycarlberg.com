---
import { Icon } from "astro-icon/components";

const today = new Date();

const socialLinks = [
  {
    href: "https://linkedin.com/in/andycarlberg",
    icon: "simple-icons:linkedin",
    label: "LinkedIn",
    isMe: true,
  },
  {
    href: "https://github.com/andycarlberg",
    icon: "simple-icons:github",
    label: "GitHub",
    isMe: true,
  },
  {
    href: "https://bsky.app/profile/andycarlberg.com",
    icon: "simple-icons:bluesky",
    label: "Bluesky",
    isMe: true,
  },
  {
    href: "https://hachyderm.io/@andycarlberg",
    icon: "simple-icons:mastodon",
    label: "Mastodon",
    isMe: true,
  },
  {
    href: "https://www.drupal.org/u/andycarlberg",
    icon: "simple-icons:drupal",
    label: "Drupal",
    isMe: false,
  },
];
---

<footer class="w-full mt-24 border-t border-slate-100 dark:border-slate-900 bg-white dark:bg-slate-950">
  <div class="max-w-7xl mx-auto px-8 py-12 flex flex-col md:flex-row justify-between items-center gap-6">
    <p class="font-manrope text-xs text-slate-500 dark:text-slate-400 uppercase tracking-widest">
      &copy; {today.getFullYear()} Andy Carlberg. All rights reserved.
    </p>
    <div class="flex gap-8">
      {socialLinks.map((link) => (
        <a 
          class="font-manrope text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors uppercase tracking-widest flex items-center gap-2"
          href={link.href}
          target="_blank" 
          rel={`noopener noreferrer ${link.isMe ? 'me' : ''}`}
          title={link.label}
        >
          <Icon name={link.icon} class="h-4 w-4" />
          <span class="hidden md:inline">{link.label}</span>
        </a>
      ))}
      <a
        class="font-manrope text-xs text-slate-500 dark:text-slate-400 hover:text-primary transition-colors uppercase tracking-widest flex items-center gap-2"
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        title="RSS Feed"
      >
        <Icon name="lucide:rss" class="h-4 w-4" />
        <span class="hidden md:inline">RSS</span>
      </a>
    </div>
  </div>
</footer>
