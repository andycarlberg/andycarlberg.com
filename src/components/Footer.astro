---
import { Icon } from "astro-icon/components";

const today = new Date();

const socialLinks = [
  {
    href: "https://linkedin.com/in/andycarlberg",
    icon: "simple-icons:linkedin",
    label: "LinkedIn",
    isMe: true,
  },
  {
    href: "https://github.com/andycarlberg",
    icon: "simple-icons:github",
    label: "GitHub",
    isMe: true,
  },
  {
    href: "https://bsky.app/profile/andycarlberg.com",
    icon: "simple-icons:bluesky",
    label: "Bluesky",
    isMe: true,
  },
  {
    href: "https://hachyderm.io/@andycarlberg",
    icon: "simple-icons:mastodon",
    label: "Mastodon",
    isMe: true,
  },
  {
    href: "https://www.drupal.org/u/andycarlberg",
    icon: "simple-icons:drupal",
    label: "Drupal",
    isMe: false,
  },
];
---

<footer class="w-full border-t border-outline-variant bg-surface-container-low">
  <div class="max-w-7xl mx-auto px-8 py-16 flex flex-col md:flex-row justify-between items-center gap-8">
    <p class="font-sans text-xs text-outline font-bold uppercase tracking-widest flex items-center h-4 m-0">
      &copy; {today.getFullYear()} Andy Carlberg. All rights reserved.
    </p>
    <nav class="flex flex-wrap justify-center gap-x-8 gap-y-4" aria-label="Social links">
      {socialLinks.map((link) => (
        <a 
          class="font-sans text-xs text-on-surface-variant hover:text-primary transition-colors font-bold uppercase tracking-widest flex items-center gap-2 group"
          href={link.href}
          target="_blank" 
          rel={`noopener noreferrer ${link.isMe ? 'me' : ''}`}
          title={link.label}
          aria-label={link.isMe ? `Follow Andy Carlberg on ${link.label}` : `View Andy Carlberg's ${link.label} profile`}
        >
          <Icon name={link.icon} class="h-4 w-4 group-hover:scale-110 transition-transform" />
          <span class="hidden md:inline">{link.label}</span>
        </a>
      ))}
      <a
        class="font-sans text-xs text-on-surface-variant hover:text-primary transition-colors font-bold uppercase tracking-widest flex items-center gap-2 group"
        href="/rss.xml"
        target="_blank"
        rel="noopener noreferrer"
        title="RSS Feed"
        aria-label="Subscribe to RSS Feed"
      >
        <Icon name="lucide:rss" class="h-4 w-4 group-hover:scale-110 transition-transform" />
        <span class="hidden md:inline">RSS</span>
      </a>
    </nav>
  </div>
</footer>
