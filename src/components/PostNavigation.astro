---
import { Icon } from "astro-icon/components";

interface PostLink {
  title: string;
  id: string;
}

interface Props {
  nextPost: PostLink | null; // The post published AFTER this one (newer)
  prevPost: PostLink | null; // The post published BEFORE this one (older)
}

const { nextPost, prevPost } = Astro.props;
---

<nav class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-outline-variant pt-12">
    {prevPost ? (
        <a href={`/insights/${prevPost.id}`} class="group p-6 rounded-xl border border-transparent hover:bg-surface-container hover:border-outline-variant transition-all">
            <div class="flex items-center gap-2 text-outline font-sans text-xs font-bold uppercase tracking-wider mb-2">
                <Icon name="lucide:arrow-left" class="w-4 h-4" />
                PREVIOUS
            </div>
            <h4 class="font-display text-xl font-bold group-hover:text-primary transition-colors line-clamp-2">
                {prevPost.title}
            </h4>
        </a>
    ) : (
        <div class="hidden md:block"></div> 
    )}

    {nextPost ? (
        <a href={`/insights/${nextPost.id}`} class="group p-6 rounded-xl border border-transparent hover:bg-surface-container hover:border-outline-variant transition-all text-right">
            <div class="flex items-center justify-end gap-2 text-outline font-sans text-xs font-bold uppercase tracking-wider mb-2">
                NEXT
                <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </div>
            <h4 class="font-display text-xl font-bold group-hover:text-primary transition-colors line-clamp-2">
                {nextPost.title}
            </h4>
        </a>
    ) : (
        <div class="hidden md:block"></div>
    )}
</nav>
