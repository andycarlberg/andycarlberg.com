---
// src/components/Tag.astro
import { formatTag, slugifyTag } from "../utils/tags";

interface Props {
  name: string;
  count: number;
}

const { name, count } = Astro.props;

// Convert the tag name for the URL slug
const tagSlug = slugifyTag(name);
const formattedName = formatTag(name);
---

<a 
    href={`/expertise/${tagSlug}`} 
    class="flex items-center space-x-2 bg-surface-container-low text-on-surface-variant hover:bg-primary hover:text-on-primary transition-colors duration-200 rounded-full px-4 py-2 text-sm font-semibold border border-outline-variant shadow-md"
>
    <span>#{formattedName}</span>
    <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-outline-variant text-xs text-on-surface-variant group-hover:bg-on-primary group-hover:text-primary transition-colors">
        {count}
    </span>
</a>
