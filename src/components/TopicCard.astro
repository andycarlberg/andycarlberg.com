---
import { Icon } from "astro-icon/components";
import { slugifyTag } from "../utils/tags";

interface Props {
  name: string;
  count: number;
  description?: string;
  icon?: string;
  class?: string;
}

const {
  name,
  count,
  description,
  icon = "lucide:layers",
  class: className,
} = Astro.props;
const tagSlug = slugifyTag(name);
---

<a 
  href={`/expertise/${tagSlug}`}
  class:list={[
    "group topic-card flex flex-col h-full bg-surface-container-low border border-outline-variant p-6 md:p-8 rounded-xl transition-all hover:bg-surface-variant hover:shadow-xl duration-300",
    className
  ]}
>
  <div class="flex justify-between items-start mb-6 md:mb-12 card-header">
    <div class="bg-secondary-container p-2 md:p-3 rounded-lg text-on-secondary-container group-hover:bg-primary group-hover:text-on-primary transition-colors icon-wrapper">
      <Icon name={icon} class="w-5 h-5 md:w-6 md:h-6" />
    </div>
    <div class="flex flex-col items-end article-metrics standard-only">
      <span class="bg-primary-container text-on-primary-container px-3 py-1 rounded-full font-sans text-xs font-black uppercase tracking-tighter shadow-sm article-count-badge">
        {count} {count === 1 ? 'Article' : 'Articles'}
      </span>
    </div>
  </div>

  <div class="card-body">
    <h2 class="font-display text-xl md:text-2xl font-bold text-on-surface mb-3 group-hover:text-primary transition-colors card-title">
      {name}
    </h2>
    <div class="hidden small-only-metrics mb-2">
       <span class="text-primary font-sans text-[10px] font-black uppercase tracking-widest">{count} {count === 1 ? 'Article' : 'Articles'}</span>
    </div>
    {description && (
      <p class="font-sans text-sm md:text-base text-on-surface-variant leading-relaxed card-description">
        {description}
      </p>
    )}
  </div>

  <div class="mt-auto pt-8 flex items-center text-primary font-sans text-xs font-bold uppercase tracking-widest group-hover:translate-x-1 transition-all card-footer">
    Explore Theme 
    <Icon name="lucide:arrow-right" class="w-3 h-3 ml-1" />
  </div>
</a>

<style>
  @reference "tailwindcss";

  /* Small Variant Styles */
  .topic-card.is-small {
    @apply p-4 flex-row items-start gap-4;
  }

  .topic-card.is-small .card-header {
    @apply mb-0 justify-start shrink-0;
  }

  .topic-card.is-small .card-body {
    @apply flex-1 flex flex-col justify-start;
  }

  .topic-card.is-small .standard-only {
    @apply hidden;
  }

  .topic-card.is-small .small-only-metrics {
    @apply block mb-0;
  }

  .topic-card.is-small .icon-wrapper {
    @apply bg-transparent p-0;
    color: var(--color-primary);
  }

  .topic-card.is-small .icon-wrapper :global(svg) {
    @apply w-8 h-8;
  }

  .topic-card.is-small .card-title {
    @apply text-base mb-0.5 leading-tight font-bold mt-0;
  }

  .topic-card.is-small .card-description,
  .topic-card.is-small .card-footer {
    @apply hidden;
  }
</style>



