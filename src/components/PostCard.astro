---
import { Image } from "astro:assets";

interface Props {
  title: string;
  slug: string;
  description: string;
  publishDate: Date;
  tags?: string[];
  // biome-ignore lint/suspicious/noExplicitAny: Images can be a string path or image object from astro:assets depending on context
  image?: any;
}

const { title, slug, description, publishDate, tags, image } = Astro.props;
const postLink = `/posts/${slug}/`;
const primaryTag = tags && tags.length > 0 ? tags[0] : "Article";

const formattedDate = publishDate.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
---

<article class="group cursor-pointer relative flex flex-col h-full">
    <a href={postLink} class="absolute inset-0 z-10"><span class="sr-only">Read {title}</span></a>
    
    <div class="aspect-[16/10] overflow-hidden rounded mb-6 bg-slate-100 dark:bg-slate-800 border border-slate-100 dark:border-slate-800 relative">
        {image ? (
            <Image
                src={image}
                alt={`Cover image for ${title}`}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 m-0 block"
            />
        ) : (
            <div class="w-full h-full bg-slate-200 dark:bg-slate-700 flex items-center justify-center group-hover:scale-105 transition-transform duration-500">
                <span class="text-slate-400 dark:text-slate-500 font-label-caps tracking-widest text-[10px] uppercase">No Image Available</span>
            </div>
        )}
    </div>
    
    <div class="flex gap-2 mb-4 relative z-20">
        <span class="font-label-caps text-[10px] text-primary uppercase border border-primary px-2 py-0.5 rounded font-semibold tracking-wider">
            {primaryTag}
        </span>
    </div>

    <h3 class="font-headline-md text-[24px] font-semibold leading-[1.3] mb-4 group-hover:text-primary transition-colors text-slate-900 dark:text-white mt-0">
        {title}
    </h3>
    
    <p class="font-body-md text-[16px] leading-[1.6] text-slate-600 dark:text-slate-400 line-clamp-2 m-0 flex-grow">
        {description}
    </p>
    
    <time class="block mt-4 font-label-caps text-slate-400 text-[10px] uppercase font-semibold tracking-wider">
        {formattedDate}
    </time>
</article>
