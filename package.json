{
  "name": "andycarlberg.com",
  "private": true,
  "author": "Andy Carlberg <andycarlberg@gmail.com> (https://www.andycarlberg.com/)",
  "description": "The professional profile and technical blog of Digital Strategist Andy Carlberg, built with Astro and hosted on Vercel.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "start": "astro dev",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "format": "biome format --write --error-on-warnings .",
    "check": "biome check --write --error-on-warnings .",
    "lint:biome": "biome lint .",
    "lint:md": "markdownlint-cli2 --fix \"src/**/*.{md,mdx}\"",
    "lint:package-json": "npmPkgJsonLint .",
    "ci:code-quality": "pnpm run check",
    "ci:docs-lint": "pnpm run lint:md",
    "ci:security": "pnpm audit --prod --audit-level high",
    "ci:dep-health": "depcheck --ignore-bin-package=false",
    "ci:license-check": "license-checker --production --onlyAllow 'MIT;ISC;BSD-3-Clause;Apache-2.0;CC0-1.0;MPL-2.0' --excludePackages 'andycarlberg.com'",
    "ci:all": "pnpm run check && pnpm run ci:docs-lint && pnpm run ci:security && pnpm run ci:dep-health && pnpm run ci:license-check",
    "deps:check": "ncu"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,astro,css}": [
      "biome check --write"
    ],
    "*.{md,mdx}": [
      "markdownlint-cli2 --fix"
    ]
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/lucide": "^1.2.108",
    "@iconify-json/simple-icons": "^1.2.83",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "^6.3.7",
    "astro-favicons": "^3.1.6",
    "astro-icon": "^1.1.5",
    "focus-trap": "^8.2.1",
    "katex": "^0.16.47",
    "reading-time": "^1.5.0",
    "rehype-katex": "^7.0.1",
    "rehype-wrap-all": "^1.1.0",
    "remark-math": "^6.0.0",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/language-server": "^2.16.9",
    "@astrojs/vercel": "^10.0.7",
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "depcheck": "^1.4.7",
    "lefthook": "^2.1.8",
    "license-checker": "^25.0.1",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "npm-check-updates": "^22.2.0",
    "npm-package-json-lint": "^10.4.0",
    "npm-package-json-lint-config-default": "^9.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-language-server": "^5.2.0",
    "vercel": "^54.2.0",
    "vite": "^7.3.2"
  },
  "pnpm": {
    "overrides": {
      "devalue": "^5.8.1",
      "fast-xml-parser": "^4.4.1"
    }
  }
}
